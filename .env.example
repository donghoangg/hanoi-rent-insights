```env
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
DATABASE_URL=
DB_HOST=
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=
SUPABASE_STORAGE_BUCKET=listing-thumbnails
USER_AGENT=
SCRAPER_DELAY=2
GEOCODER_USER_AGENT=
# Google Maps Geocoding API key — provider geocode chính (chính xác nhất).
# Bật API "Geocoding API" trong Google Cloud Console. Để trống = chỉ dùng Nominatim.
GOOGLE_MAPS_API_KEY=
```
