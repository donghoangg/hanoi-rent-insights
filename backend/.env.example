# ============================================================
# Backend (FastAPI) — biến môi trường
# Copy file này thành backend/.env và điền giá trị thật.
# (Có thể tái dùng DATABASE_URL từ .env gốc của dự án.)
# ============================================================

# Chuỗi kết nối PostgreSQL trên Supabase (BẮT BUỘC).
# Lấy ở Supabase: Project Settings → Database → Connection string (URI).
# Khuyến nghị dùng "Connection pooling" (port 6543) cho serverless/Render.
DATABASE_URL=postgresql://postgres.xxxx:YOUR_PASSWORD@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres

# Tên schema Gold (mặc định: gold)
GOLD_SCHEMA=gold

# Các origin được phép gọi API (frontend). Phân tách bằng dấu phẩy.
# Local dev: http://localhost:3000
# Production: thêm URL Vercel, vd https://hanoirent.vercel.app
# Dùng "*" để mở cho mọi origin (chỉ nên dùng khi demo).
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
